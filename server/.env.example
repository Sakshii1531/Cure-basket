PORT=5001
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
NODE_ENV=development
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
FRONTEND_ORIGIN=http://localhost:5173

SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change_this_strong_password

# Email (SMTP) — required for welcome emails, password reset, etc.
# Gmail: use a 16-char App Password (Google Account → Security → App Passwords), NOT your login password
# FROM_EMAIL must match your SMTP_USER (Gmail doesn't allow spoofing a different From address)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
FROM_NAME=CureBasket
FROM_EMAIL=your_gmail@gmail.com
